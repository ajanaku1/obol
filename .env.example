# Obol — environment template. Copy to .env and fill in. Never commit .env.

# --- Agent core (Anthropic) ---
ANTHROPIC_API_KEY=

# --- Arc testnet ---
# Arc testnet RPC. Get a key from the Arc builder portal.
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
# USDC token contract on Arc testnet (native gas asset).
ARC_USDC_ADDRESS=

# --- Obol's Circle Agent Wallet ---
# The agent's spending wallet. Created via `npm run wallet:create`.
# The private key is loaded at runtime ONLY — it is never committed.
OBOL_WALLET_ADDRESS=
OBOL_WALLET_PRIVATE_KEY=

# --- x402 facilitator ---
# Settles signed payment authorizations on Arc. Defaults to the local
# facilitator bundled with the payments MCP server.
X402_FACILITATOR_URL=http://localhost:4021
X402_FACILITATOR_PORT=4021
# Optional: a dedicated relayer key so the facilitator pays gas instead of
# Obol — making payments fully gasless. If unset, Obol's wallet self-relays.
X402_FACILITATOR_RELAYER_KEY=

# --- Data vendor server (the x402 market Obol shops) ---
DATA_SERVER_URL=http://localhost:4020
DATA_SERVER_PORT=4020
# Where vendor revenue is paid. Use any Arc address you control.
VENDOR_PAYOUT_ADDRESS=

# Optional: Tavily web-search API key for the Deep Research vendor (https://tavily.com).
# If unset, Deep Research falls back to the DuckDuckGo Instant Answer API.
TAVILY_API_KEY=
